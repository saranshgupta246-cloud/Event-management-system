PORT=5000
MONGODB_URI=mongodb://localhost:27017/mits_clubs
JWT_SECRET=your_secret_here
JWT_EXPIRES_IN=15d
NODE_ENV=development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@mits.ac.in
FROM_NAME=MITS Event System
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=admin@mits.ac.in

# Google login (Firebase Admin). Get from Firebase Console > Project Settings > Service accounts.
# For FIREBASE_PRIVATE_KEY: paste the private_key from the JSON; use \n for newlines if needed.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_firebase_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
